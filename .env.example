# ============================================================
# NexDial — Variáveis de Ambiente
# ============================================================
# Copie este arquivo para .env e preencha os valores reais.
# NUNCA comite o .env no Git (já está no .gitignore).
# Em produção (Railway, VPS), configure estas variáveis no painel
# da plataforma — não use arquivo .env no servidor.
# ============================================================

# ─── Flask ───────────────────────────────────────────────────
FLASK_ENV=production

# Gere com: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=GERE_UMA_CHAVE_SEGURA_AQUI

# ─── Banco de Dados ──────────────────────────────────────────
# PostgreSQL (Railway, Supabase, Neon, RDS, etc.)
# Formato: postgresql://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=postgresql://nexdial_user:senha@host:5432/nexdial

# SQLite (somente desenvolvimento local, NÃO usar em produção)
# DATABASE_URL=sqlite:///nexdial.db

# ─── Segurança / Criptografia ────────────────────────────────
# Chave Fernet para criptografar tokens Twilio por tenant
# Gere com: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# ATENÇÃO: Mude esta chave e perca o acesso a todos os tokens criptografados.
# Salve a chave em local seguro (ex: 1Password, Bitwarden).
FERNET_KEY=GERE_UMA_CHAVE_FERNET_AQUI

# ─── Redis (recomendado em produção) ─────────────────────────
# Railway: adicione serviço Redis e use ${{Redis.REDIS_URL}}
# Sem Redis: 1 worker Gunicorn + estado in-memory (não recomendado)
REDIS_URL=redis://localhost:6379/0

# ─── Admin ───────────────────────────────────────────────────
# Email promovido automaticamente a superadmin no startup
SUPERADMIN_EMAIL=seu@email.com

# ─── Twilio (Conta Master / Conta de Teste) ──────────────────
# Conta principal usada para chamadas (e para criar subcontas por cliente no futuro)
# Conta de TESTE Twilio: SID começa com AC, Auth Token tem 32 chars
# Conta REAL Twilio: mesma estrutura, sem restrições de número verificado
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+55XXXXXXXXXX

# API Key da conta master (para AccessToken do webphone / Voice SDK)
# Crie em: Twilio Console → Account → API Keys & Tokens → Create API Key
TWILIO_API_KEY=SKxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_API_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# SID do TwiML App (criado no Console Twilio → Voice → TwiML Apps)
# Voice Request URL deve apontar para: {PUBLIC_BASE_URL}/api/twilio/browser-outgoing
TWILIO_TWIML_APP_SID=APxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Validação de assinatura dos webhooks Twilio (false apenas em dev/ngrok)
TWILIO_VALIDATE_WEBHOOKS=true

# Bundle regulatório para compra de números BR (opcional)
TWILIO_BUNDLE_SID=BUxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_ADDRESS_SID=ADxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── URLs ────────────────────────────────────────────────────
# URL pública do backend (sem barra no final)
# Railway Faextech: https://SEU-SERVICO.up.railway.app
# Desenvolvimento com ngrok: https://seu-id.ngrok-free.dev
BASE_URL=https://seu-app.railway.app
PUBLIC_BASE_URL=https://seu-app.railway.app

# CORS — separar por vírgula, sem espaços (inclua a URL do Railway)
CORS_ORIGINS=https://seu-app.railway.app,http://localhost:5173

# ─── Pagamento (MercadoPago) ─────────────────────────────────
# Obtenha em: https://www.mercadopago.com.br/developers
# Produção: APP_USR-...  | Sandbox/Teste: TEST-...
MERCADOPAGO_ACCESS_TOKEN=APP_USR-xxxxxxxxxxxxxxxx
MERCADOPAGO_PUBLIC_KEY=APP_USR-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ─── Ambiente ────────────────────────────────────────────────
ENVIRONMENT=production
